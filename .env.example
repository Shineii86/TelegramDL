# Telegram API Credentials (Required)
API_ID=
API_HASH=
BOT_TOKEN=

# User session for restricted content (Optional)
# Set to "false" to use global STRING_SESSION instead of per-user login
LOGIN_SYSTEM=true
STRING_SESSION=

# Database (Required if LOGIN_SYSTEM=true)
DB_URI=
DB_NAME=telegramdl

# Bot Settings
ADMINS=
CHANNEL_ID=
WAITING_TIME=10
ERROR_MESSAGE=true

# Download Settings
OUTPUT_DIR=./downloads
MAX_FILE_SIZE_MB=2048
TYPE_FILTER=all
