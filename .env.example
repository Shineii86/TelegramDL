# TelegramDL Environment Variables
# Copy this file to .env and fill in your values

# Telegram API (Required)
API_ID=
API_HASH=
BOT_TOKEN=

# MongoDB (Required)
DB_URI=

# Admin Settings (Optional - comma-separated user IDs)
ADMINS=

# Channel Settings (Optional)
CHANNEL_ID=

# Logging (Optional)
LOG_CHANNEL=

# Force Subscribe (Optional)
FORCE_SUB=

# User Session (Optional - for restricted content)
STRING_SESSION=

# Login System
LOGIN_SYSTEM=True

# Limits
FREE_DAILY_LIMIT=10
FREE_MAX_FILE_SIZE_MB=2000
PREMIUM_MAX_FILE_SIZE_MB=4000

# Links (Optional)
ADMIN_CONTACT=
JOIN_LINK=

# Keep-Alive (Optional - for Colab)
KEEP_ALIVE=False

# Checkpoint (Optional - resume batch downloads)
USE_CHECKPOINT=False

# Waiting Time (Optional - seconds between downloads)
WAITING_TIME=3

# Security Keys (Required - for session encryption)
MASTER_KEY=Change_Me_To_Random_String_2024!
IV_KEY=Change_Me_Salt_2024!

# Type Filter (Optional - photo, video, audio, document, all)
TYPE_FILTER=all

# Forward Mode (Optional - use forwarding instead of re-uploading)
FORWARD_MODE=False

# Caption Settings (Optional)
CAPTION_ENABLED=False
KEEP_ORIGINAL_CAPTION=False
