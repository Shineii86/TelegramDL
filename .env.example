# TelegramDL Environment Variables
# Copy this file to .env and fill in your values

# Telegram API (Required)
API_ID=
API_HASH=
BOT_TOKEN=

# MongoDB (Required)
MONGO_DB=

# Owner Settings (Required)
OWNER_ID=

# Logging (Required)
LOG_GROUP=

# Force Subscribe (Optional)
FORCE_SUB=

# User Session (Optional - for restricted content)
STRING=

# Login System
LOGIN_SYSTEM=True

# Limits
FREE_DAILY_LIMIT=10
FREE_MAX_FILE_SIZE_MB=2000
PREMIUM_MAX_FILE_SIZE_MB=4000

# Links (Optional)
ADMIN_CONTACT=
JOIN_LINK=
