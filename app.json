{
  "name": "TelegramDL",
  "description": "Advanced Telegram Downloader Bot with Premium System, yt-dlp, File Splitting & More",
  "logo": "https://raw.githubusercontent.com/Shineii86/TelegramDL/main/assets/logo.png",
  "keywords": ["python3", "telegram", "telegram-bot", "ftmgram", "downloader"],
  "repository": "https://github.com/Shineii86/TelegramDL",
  "success_url": "https://github.com/Shineii86/TelegramDL",
  "env": {
    "API_ID": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "API_HASH": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Bot token from @BotFather",
      "value": "",
      "required": true
    },
    "DB_URI": {
      "description": "MongoDB connection URL (https://cloud.mongodb.com)",
      "value": "",
      "required": true
    },
    "DB_NAME": {
      "description": "Database name for MongoDB",
      "value": "telegram_downloader",
      "required": false
    },
    "ADMINS": {
      "description": "Comma-separated admin Telegram user IDs",
      "value": "",
      "required": false
    },
    "CHANNEL_ID": {
      "description": "Channel ID for auto-upload (with -100 prefix)",
      "value": "",
      "required": false
    },
    "LOG_CHANNEL": {
      "description": "Log channel ID (with -100 prefix)",
      "value": "",
      "required": false
    },
    "FORCE_SUB": {
      "description": "Force subscribe channel ID (with -100 prefix)",
      "value": "",
      "required": false
    },
    "STRING_SESSION": {
      "description": "Optional session string for restricted content",
      "value": "",
      "required": false
    },
    "LOGIN_SYSTEM": {
      "description": "Enable per-user login (True/False)",
      "value": "True",
      "required": false
    },
    "FREE_DAILY_LIMIT": {
      "description": "Daily download limit for free users",
      "value": "10",
      "required": false
    },
    "FREE_MAX_FILE_SIZE_MB": {
      "description": "Max file size for free users (MB)",
      "value": "2000",
      "required": false
    },
    "PREMIUM_MAX_FILE_SIZE_MB": {
      "description": "Max file size for premium users (MB)",
      "value": "4000",
      "required": false
    },
    "ADMIN_CONTACT": {
      "description": "Admin contact username (without @)",
      "value": "",
      "required": false
    },
    "KEEP_ALIVE": {
      "description": "Enable keep-alive server (True/False)",
      "value": "False",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [],
  "stack": "container"
}
